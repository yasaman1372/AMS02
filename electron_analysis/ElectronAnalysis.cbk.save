[interactive]
creat acqt files for ISS data
command:make_ACQT_filelist.py 
args:ISS B1130_pass7_7.9
ref:ISSacqtfiles
depends:none

[interactive]
creat acqt files for MC electron data
command: make_ACQT_filelist.py 
args: -r -o ElectronMontecarlo.list MC "B1220_el.*_7.9"
ref:ElectronMCacqtfiles
depends:none

