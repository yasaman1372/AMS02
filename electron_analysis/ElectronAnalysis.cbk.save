[interactive]
Produce MC scaling file
command: produce_mc_scalings --inputlist $TASK[ElectronMCacqtfiles]/ElectronMontecarlo.list
ref:ElectronMCscaling
depends:ElectronMCacqtfiles


[acqt]
run tree writer for ISS data
job:ExampleAnalysisTreeWriter
filelist:$TASK[ISSacqtfiles]/B1130_pass7_7.9_all.list
args:--mpi --partition c18m --nruns 20
nexpected_per_job: 0
nexpected_per_process: 2
ref:ISSTreeWriter
depends: ISSacqtfiles

[acqt]
run tree writer	for MC electron 
job:ExampleAnalysisTreeWriter
filelist:$TASK[ElectronMCacqtfiles]/ElectronMontecarlo.list
args:--mpi --partition c18m --nruns 20  --arguments "--McSpectrumScaler/inputfile $TASK[ElectronMCscaling]/mcScalingWeights.root"
nexpected_per_job: 0
nexpected_per_process: 2
ref:MCelectronTreeWriter
depends: ElectronMCacqtfiles, ElectronMCscaling

[generic]
creat histograms for ISS electron data
job:electron_2Dhist.py
args: --threads_per_job 48 --arguments "--title ISS  $TASK[ISSTreeWriter]/results/ExampleAnalysis_Tree\*.root" 
nmin:0
nmax:0
ref:ISSelectronHistogram
depends:ISSTreeWriter

[generic]
creat histograms for MC electron data
job:electron_2Dhist.py
args: --threads_per_job 48 --arguments "--title MC $TASK[MCelectronTreeWriter]/results/ExampleAnalysis_Tree\*.root"
nmin:0 
nmax:0
ref:MCelectronhistogram
depends:MCelectronTreeWriter

